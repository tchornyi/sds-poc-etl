# PostgreSQL connection settings for the ETL target database.
# Copy this file to `.env` and adjust the values, or export these as real
# environment variables. The ETL reads them at runtime.

# Option A: a single libpq connection string (takes precedence if set).
# DATABASE_URL=postgresql://user:password@localhost:5432/weather

# Option B: individual components (used when DATABASE_URL is not set).
PGHOST=localhost
PGPORT=5432
PGDATABASE=weather
PGUSER=postgres
PGPASSWORD=postgres
# PGSSLMODE=prefer
